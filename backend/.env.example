# ========================================
# 山东新航实验外国语学校 - 后端环境变量配置
# ========================================
# 使用方法：复制本文件为 .env，然后填入你的实际配置
# cp .env.example .env

# ---- 服务端口 ----
PORT=8080

# ---- PostgreSQL 数据库 ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=xinhang_user
DB_PASSWORD=your_database_password_here
DB_NAME=xinhang
DB_MAX_CONNS=50
DB_IDLE_CONNS=10

# ---- Redis ----
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT 认证 ----
# 请替换为一个随机的 32 位以上字符串，可用以下命令生成：
# openssl rand -hex 32
JWT_SECRET=please_replace_with_random_string

# ---- 邮件发送 (SMTP) ----
# 用于发送注册验证码
# QQ 邮箱示例：
#   SMTP_HOST=smtp.qq.com, SMTP_PORT=465
#   SMTP_PASSWORD 填授权码（非登录密码）
#   获取方式：QQ邮箱 → 设置 → 账户 → 开启 SMTP → 生成授权码
# 163 邮箱示例：
#   SMTP_HOST=smtp.163.com, SMTP_PORT=465
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_email@qq.com

# ---- 准考证验证 PIN ----
# 教职工扫码验证准考证时需要输入的密码
VERIFY_PIN=xinhang2026
