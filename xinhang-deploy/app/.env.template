# ========================================
# 山东新航实验外国语学校 - 后端环境变量配置模板
# ========================================
# 此文件由部署脚本 04-configure-env.sh 自动填充
# 也可以手动编辑：nano /data/xinhang-app/backend/.env

# 服务端口
PORT=8080

# PostgreSQL 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=xinhang_user
DB_PASSWORD=【步骤2中设置的数据库密码】
DB_NAME=xinhang
DB_MAX_CONNS=50
DB_IDLE_CONNS=10

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 认证密钥（用此命令生成: openssl rand -hex 32）
JWT_SECRET=【请替换为随机字符串】

# 邮件发送 (SMTP)
# QQ邮箱: SMTP_HOST=smtp.qq.com, SMTP_PORT=465
# 163邮箱: SMTP_HOST=smtp.163.com, SMTP_PORT=465
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=【发件邮箱地址】
SMTP_PASSWORD=【邮箱授权码，不是登录密码】
SMTP_FROM=【发件邮箱地址，同SMTP_USER】

# 准考证验证 PIN（教职工扫码验证时输入的密码）
VERIFY_PIN=xinhang2026
